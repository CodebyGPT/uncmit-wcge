<policyDefinitions revision="1.0" schemaVersion="1.0">
  <policyNamespaces>
    <target prefix="CMGECustomPolicy" namespace="Microsoft.Policies.CMGECustomPolicy" />
    <using prefix="windows" namespace="Microsoft.Policies.Windows" />
  </policyNamespaces>
  <resources minRequiredRevision="1.0" />
  <supportedOn>
    <definitions>
      <definition name="SUPPORTED_Windows10" displayName="$(string.SUPPORTED_Windows10)" />
    </definitions>
  </supportedOn>
  <categories>
    <category name="Cat_CMGECP" displayName="$(string.CMGECP)" />
  </categories>
  <policies>  
	   <policy
        name="Pol_WHMCP_LetWebsitesProvideLocallyRelevantContentByAccessingMyLanguageList"
        displayName="$(string.LWPLRCBAMLL)"
        explainText="$(string.LWPLRCBAMLL_Help)"
        class="User"
        key="Control Panel\International\User Profile"
        valueName="HttpAcceptLanguageOptOut">
          <parentCategory ref="Cat_CMGECP" />
          <supportedOn ref="SUPPORTED_Windows10" />
          <enabledValue>
            <decimal value="0"/>
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
    <!--
        1 for no traffic
        other choice is 0 or delete value
    -->
    </policy>
    
    <policy
        name="Pol_WHMCP_MessagingCloudSync"
        displayName="$(string.MessagingCloudSync)"
        explainText="$(string.MessagingCloudSync_Help)"
        class="User"
        key="SOFTWARE\Microsoft\Messaging"
        valueName="CloudServiceSyncEnabled">
          <parentCategory ref="Cat_CMGECP" />
          <supportedOn ref="SUPPORTED_Windows10" />
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
    <!--
        0 for no traffic
        Choices: 0 or 1 (delete)
    -->
    </policy>
    
    <policy
        name="Pol_WHMCP_TurnOffMaliciousSoftwareReporting"
        displayName="$(string.TurnOffMaliciousSoftwareReporting)"
        explainText="$(string.TurnOffMaliciousSoftwareReporting_Help)"
        class="Machine"
        key="Software\Policies\Microsoft\MRT"
        valueName="DontReportInfectionInformation">
          <parentCategory ref="Cat_CMGECP" />
          <supportedOn ref="SUPPORTED_Windows10" />
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
    <!--
        1 for no traffic
        Choices: 1 or 0 / delete
    -->
    </policy>
    <policy 
		name="Pol_WHMCP_PreventNetworkTrafficPreUserSignIn" 
		class="Machine" 
		displayName="$(string.BlockOneDriveNetworkActivityUntilUserSignIn)" 
		explainText="$(string.BlockOneDriveNetworkActivityUntilUserSignIn_help)" 
		key="SOFTWARE\Microsoft\OneDrive" valueName="PreventNetworkTrafficPreUserSignIn">
      <parentCategory ref="Cat_CMGECP" />
      <supportedOn ref="windows:SUPPORTED_Windows7" />
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
	<!--
        1 for no traffic
        Choices: 1 or 0 / delete
    -->
    </policy>
	
	
    <policy 
		name="Pol_WHMCP_EanbleTrackProgramsInStart" 
		class="User" 
		displayName="$(string.Pol_WHMCP_EanbleTrackProgramsInStart)" 
		explainText="$(string.Pol_WHMCP_EanbleTrackProgramsInStart_Help)" 
		key="SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced" 
		valueName="Start_TrackProgs">
      <parentCategory ref="Cat_CMGECP" />
      <supportedOn ref="windows:SUPPORTED_WindowsVista" />
	      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
	<!--
        0 for no traffic
        Choices: 1 or 0 / delete
    -->
    </policy>
	
    <policy 
		name="Pol_WHMCP_EnableWebContentEvaluation" 
		class="User" 
		displayName="$(string.Pol_WHMCP_EnableWebContentEvaluation)" 
		explainText="$(string.Pol_WHMCP_EnableWebContentEvaluation_Help)" 
		key="SOFTWARE\Microsoft\Windows\CurrentVersion\AppHost" 
		valueName="EnableWebContentEvaluation">
      <parentCategory ref="Cat_CMGECP" />
      <supportedOn ref="windows:SUPPORTED_WindowsVista" />
	  <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
	<!--
        0 for no traffic
        Choices: 1 or 0 / delete
    -->
    </policy>
  
    <policy
        name="Pol_CMGECP_AdvertisingInfo"
        displayName="$(string.AdvertisingInfo)"
        explainText="$(string.AdvertisingInfo_Help)"
        class="User"
        key="SOFTWARE\Microsoft\Windows\CurrentVersion\AdvertisingInfo"
        valueName="Enabled">
          <parentCategory ref="Cat_CMGECP" />
          <supportedOn ref="SUPPORTED_Windows10" />
          <enabledValue>
            <decimal value="0"/>
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
    <!--
        0 for no traffic
        other choice is 1 or delete value
    -->	
    </policy>  
  
    <policy
        name="Pol_CMGECP_TailoredExperiencesWithDiagnosticDataEnabled"
        displayName="$(string.TailoredExperiencesWithDiagnosticDataEnabled)"
        explainText="$(string.TailoredExperiencesWithDiagnosticDataEnabled_Help)"
        class="Machine"
        key="SOFTWARE\Microsoft\Windows\CurrentVersion\Privacy"
        valueName="TailoredExperiencesWithDiagnosticDataEnabled">
          <parentCategory ref="Cat_CMGECP" />
          <supportedOn ref="SUPPORTED_Windows10" />
          <enabledValue>
            <decimal value="0"/>
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
    <!--
        0 for no traffic
        other choice is 1 or delete value
    -->	
    </policy>
	
	<policy 
		name="Pol_CMGECP_DelayLockInterval"		
		displayName="$(string.DelayLockInterval)"
		explainText="$(string.DelayLockInterval_Help)"
		class="User"
		presentation="$(presentation.StandbyDelayLockInterval)" 
		key="Control Panel\Desktop">
		  <parentCategory ref="Cat_CMGECP" />
		  <supportedOn ref="SUPPORTED_Windows10" />
		  <elements>
			<decimal id="StandbyDelayLockIntervalTime" valueName="DelayLockInterval" required="true" maxValue="4294967295" />
		  </elements>
    </policy>
	
    <policy
	  name="Pol_CMGECP_DisableFeedback"
	  class="User"
	  displayName="$(string.DisableFeedback)"
	  explainText="$(string.DisableFeedback_Help)"
	  key="SOFTWARE\Microsoft\Siuf\Rules">
        <parentCategory ref="Cat_CMGECP" />
        <supportedOn ref="SUPPORTED_Windows10" />
        <enabledList>
          <item key="SOFTWARE\Microsoft\Siuf\Rules" valueName="NumberOfSIUFInPeriod">
            <value>
              <decimal value="0" />
            </value>
          </item>
          <item key="SOFTWARE\Microsoft\Siuf\Rules" valueName="PeriodInNanoSeconds">
            <value>
              <decimal value="0" />
            </value>
          </item>
        </enabledList>
        <disabledList>
          <item key="SOFTWARE\Microsoft\Siuf\Rules" valueName="NumberOfSIUFInPeriod">
            <value>
              <delete />
            </value>
          </item>
          <item key="SOFTWARE\Microsoft\Siuf\Rules" valueName="PeriodInNanoSeconds">
            <value>
              <delete />
            </value>
          </item>
      </disabledList>
    </policy>
	
	<policy
	  name="Pol_CMGECP_TurnoffInkingTypingDataCollection"
	  class="User"
	  displayName="$(string.TurnoffInkingTypingDataCollection)"
	  explainText="$(string.TurnoffInkingTypingDataCollection_Help)"
	  key="SOFTWARE\Microsoft\InputPersonalization">
        <parentCategory ref="Cat_CMGECP" />
        <supportedOn ref="SUPPORTED_Windows10" />
        <enabledList>
          <item key="SOFTWARE\Microsoft\InputPersonalization" valueName="RestrictImplicitInkCollection">
            <value>
              <decimal value="1" />
            </value>
          </item>
          <item key="SOFTWARE\Microsoft\InputPersonalization" valueName="RestrictImplicitTextCollection">
            <value>
              <decimal value="1" />
            </value>
          </item>
		  <item key="SOFTWARE\Microsoft\InputPersonalization\TrainedDataStore" valueName="HarvestContacts">
            <value>
              <decimal value="0" />
            </value>
          </item>
		  <item key="SOFTWARE\Microsoft\Personalization\Settings" valueName="AcceptedPrivacyPolicy">
            <value>
              <decimal value="0" />
            </value>
          </item>
        </enabledList>
        <disabledList>
          <item key="SOFTWARE\Microsoft\InputPersonalization" valueName="RestrictImplicitInkCollection">
            <value>
              <decimal value="0" />
            </value>
          </item>
          <item key="SOFTWARE\Microsoft\InputPersonalization" valueName="RestrictImplicitTextCollection">
            <value>
              <decimal value="0" />
            </value>
          </item>
		  <item key="SOFTWARE\Microsoft\InputPersonalization\TrainedDataStore" valueName="HarvestContacts">
            <value>
              <decimal value="1" />
            </value>
          </item>
		  <item key="SOFTWARE\Microsoft\Personalization\Settings" valueName="AcceptedPrivacyPolicy">
            <value>
              <decimal value="1" />
            </value>
          </item>
      </disabledList>
    </policy>
  </policies>
</policyDefinitions>
